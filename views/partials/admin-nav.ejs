<div class="admin-topbar">
  <div class="admin-topbar-inner">
    <button class="sidebar-toggle" id="sidebarToggle"><i class="fas fa-bars"></i></button>
    <div class="admin-brand">
      <img src="/images/logo.png" alt="SJ" style="height:32px">
      <span>Admin Panel</span>
    </div>
    <div class="admin-topbar-right">
      <span class="admin-user"><i class="fas fa-user-circle"></i> <%= adminUsername %></span>
      <a href="/" target="_blank" class="admin-top-link" title="View Website"><i class="fas fa-external-link-alt"></i></a>
      <a href="/admin/logout" class="admin-top-link" title="Logout"><i class="fas fa-sign-out-alt"></i></a>
    </div>
  </div>
</div>
