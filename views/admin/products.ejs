<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/images/logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<%- include('../partials/admin-nav') %>
<div class="admin-layout">
  <%- include('../partials/admin-sidebar') %>
  <main class="admin-main">
    <div class="admin-header">
      <h1>Products <span class="count-badge"><%= products.length %></span></h1>
      <div style="display:flex;gap:10px;align-items:center">
        <a href="/admin/products/export" class="btn-admin-secondary" title="Export to Excel">
          <i class="fas fa-file-excel"></i> Export Excel
        </a>
        <a href="/admin/products/import" class="btn-admin-secondary" title="Import from Excel">
          <i class="fas fa-file-upload"></i> Import
        </a>
        <a href="/admin/products/export" class="btn-admin-secondary" title="Export to Excel">
          <i class="fas fa-file-excel"></i> Export
        </a>
        <a href="/admin/products/add" class="btn-admin-primary"><i class="fas fa-plus"></i> Add Product</a>
      </div>
    </div>

    <!-- Filters -->
    <form method="GET" action="/admin/products" class="filter-bar">
      <input type="text" name="search" placeholder="Search products…" value="<%= search %>" class="filter-input">
      <select name="category" class="filter-select">
        <option value="">All Categories</option>
        <option value="gold"    <%= category==='gold'   ?'selected':'' %>>Gold</option>
        <option value="diamond" <%= category==='diamond'?'selected':'' %>>Diamond</option>
        <option value="silver"  <%= category==='silver' ?'selected':'' %>>Silver</option>
      </select>
      <button type="submit" class="btn-admin-primary"><i class="fas fa-search"></i> Search</button>
      <% if (search || category) { %>
      <a href="/admin/products" class="btn-admin-secondary">Clear</a>
      <% } %>
    </form>

    <div class="admin-card">
      <div class="table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Image</th><th>Name</th><th>Category</th><th>Price</th>
              <th>Weight</th><th>Purity</th><th>Featured</th><th>Status</th><th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (products.length === 0) { %>
            <tr><td colspan="9" class="empty-row">No products found. <a href="/admin/products/add">Add your first product</a></td></tr>
            <% } %>
            <% products.forEach(p => { %>
            <tr>
              <td>
                <% if (p.image) { %>
                  <img src="<%= p.image %>" alt="" class="table-thumb">
                <% } else { %>
                  <div class="table-thumb-placeholder"><i class="fas fa-image"></i></div>
                <% } %>
              </td>
              <td><strong><%= p.name %></strong></td>
              <td><span class="cat-badge cat-badge-<%= p.category %>"><%= p.category %></span></td>
              <td>₹<%= Number(p.price).toLocaleString('en-IN') %></td>
              <td><%= p.weight > 0 ? p.weight + ' ' + p.weight_unit : '—' %></td>
              <td><%= p.purity || '—' %></td>
              <td>
                <% if (p.is_featured) { %>
                  <i class="fas fa-star" style="color:#d4af37" title="Featured"></i>
                <% } else { %>
                  <i class="fas fa-star" style="color:#444" title="Not Featured"></i>
                <% } %>
              </td>
              <td><span class="status-badge <%= p.is_active?'active':'inactive' %>"><%= p.is_active?'Active':'Hidden' %></span></td>
              <td class="action-btns">
                <a href="/admin/products/edit/<%= p.id %>" class="btn-icon edit" title="Edit"><i class="fas fa-edit"></i></a>
                <a href="/product/<%= p.id %>" target="_blank" class="btn-icon view" title="View on site"><i class="fas fa-eye"></i></a>
                <form method="POST" action="/admin/products/toggle/<%= p.id %>" style="display:inline">
                  <button type="submit" class="btn-icon toggle" title="<%= p.is_active?'Hide':'Show' %>">
                    <i class="fas fa-<%= p.is_active?'eye-slash':'eye' %>"></i>
                  </button>
                </form>
                <form method="POST" action="/admin/products/delete/<%= p.id %>" style="display:inline" class="delete-form">
                  <button type="submit" class="btn-icon del" title="Delete" data-name="<%= p.name %>"><i class="fas fa-trash"></i></button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<script src="/js/main.js"></script>
</body>
</html>
