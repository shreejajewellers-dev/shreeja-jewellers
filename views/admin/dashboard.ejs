<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/images/logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<%- include('../partials/admin-nav') %>

<div class="admin-layout">
  <%- include('../partials/admin-sidebar') %>

  <main class="admin-main">
    <div class="admin-header">
      <h1>Dashboard</h1>
      <a href="/admin/products/add" class="btn-admin-primary"><i class="fas fa-plus"></i> Add Product</a>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon all"><i class="fas fa-boxes"></i></div>
        <div class="stat-info">
          <span class="stat-num"><%= stats.total %></span>
          <span class="stat-label">Total Products</span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon gold"><i class="fas fa-crown"></i></div>
        <div class="stat-info">
          <span class="stat-num"><%= stats.gold %></span>
          <span class="stat-label">Gold Products</span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon diamond"><i class="fas fa-gem"></i></div>
        <div class="stat-info">
          <span class="stat-num"><%= stats.diamond %></span>
          <span class="stat-label">Diamond Products</span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon silver"><i class="fas fa-star"></i></div>
        <div class="stat-info">
          <span class="stat-num"><%= stats.silver %></span>
          <span class="stat-label">Silver Products</span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon featured"><i class="fas fa-star"></i></div>
        <div class="stat-info">
          <span class="stat-num"><%= stats.featured %></span>
          <span class="stat-label">Featured</span>
        </div>
      </div>
    </div>

    <!-- Recent Products -->
    <div class="admin-card">
      <div class="card-header">
        <h2>Recent Products</h2>
        <a href="/admin/products" class="link-more">View All <i class="fas fa-arrow-right"></i></a>
      </div>
      <div class="table-wrap">
        <table class="admin-table">
          <thead>
            <tr><th>Image</th><th>Name</th><th>Category</th><th>Price</th><th>Weight</th><th>Status</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% if (recent.length === 0) { %>
            <tr><td colspan="7" class="empty-row">No products yet. <a href="/admin/products/add">Add your first product</a></td></tr>
            <% } %>
            <% recent.forEach(p => { %>
            <tr>
              <td>
                <% if (p.image) { %>
                  <img src="<%= p.image %>" alt="" class="table-thumb">
                <% } else { %>
                  <div class="table-thumb-placeholder"><i class="fas fa-image"></i></div>
                <% } %>
              </td>
              <td><strong><%= p.name %></strong></td>
              <td><span class="cat-badge cat-badge-<%= p.category %>"><%= p.category %></span></td>
              <td>₹<%= Number(p.price).toLocaleString('en-IN') %></td>
              <td><%= p.weight > 0 ? p.weight + ' ' + p.weight_unit : '—' %></td>
              <td><span class="status-badge <%= p.is_active?'active':'inactive' %>"><%= p.is_active?'Active':'Hidden' %></span></td>
              <td>
                <a href="/admin/products/edit/<%= p.id %>" class="btn-icon" title="Edit"><i class="fas fa-edit"></i></a>
                <a href="/product/<%= p.id %>" target="_blank" class="btn-icon" title="View"><i class="fas fa-eye"></i></a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="quick-links">
      <a href="/admin/products/add" class="quick-link">
        <i class="fas fa-plus-circle"></i><span>Add Product</span>
      </a>
      <a href="/admin/products?category=gold" class="quick-link gold">
        <i class="fas fa-crown"></i><span>Gold Products</span>
      </a>
      <a href="/admin/products?category=diamond" class="quick-link diamond">
        <i class="fas fa-gem"></i><span>Diamond Products</span>
      </a>
      <a href="/admin/products?category=silver" class="quick-link silver">
        <i class="fas fa-star"></i><span>Silver Products</span>
      </a>
      <a href="/" target="_blank" class="quick-link">
        <i class="fas fa-external-link-alt"></i><span>View Website</span>
      </a>
    </div>

  </main>
</div>
<script src="/js/main.js"></script>
</body>
</html>
