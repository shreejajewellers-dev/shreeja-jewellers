<%- include('../partials/admin-nav') %>
<div class="admin-layout">
  <%- include('../partials/admin-sidebar') %>
  <main class="admin-main">

    <!-- Page Header -->
    <div class="pg-header">
      <div class="pg-header-left">
        <div class="pg-icon"><i class="fas fa-cog"></i></div>
        <div>
          <h1 class="pg-title">Settings</h1>
          <p class="pg-sub">Configure analytics, email notifications and store preferences</p>
        </div>
      </div>
      <button type="submit" form="settings-form" class="pg-save-btn">
        <i class="fas fa-save"></i> Save Settings
      </button>
    </div>

    <!-- Alerts -->
    <% if (success) { %>
    <div class="pg-alert pg-alert-success">
      <i class="fas fa-check-circle"></i>
      <span><%= success %></span>
      <button class="pg-alert-close" onclick="this.parentElement.remove()">&times;</button>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="pg-alert pg-alert-error">
      <i class="fas fa-exclamation-circle"></i>
      <span><%= error %></span>
      <button class="pg-alert-close" onclick="this.parentElement.remove()">&times;</button>
    </div>
    <% } %>

    <form id="settings-form" method="POST" action="/admin/settings" class="settings-grid">

      <!-- ── Google Analytics ───────────────────────────────── -->
      <div class="set-card">
        <div class="set-card-top ga-top">
          <div class="set-card-icon"><i class="fab fa-google"></i></div>
          <div>
            <h2>Google Analytics</h2>
            <p>Track visitors, sessions and user behaviour in real time</p>
          </div>
          <div class="set-card-status">
            <% if (settings.ga4_id) { %>
              <span class="status-chip on"><i class="fas fa-circle"></i> Active</span>
            <% } else { %>
              <span class="status-chip off"><i class="fas fa-circle"></i> Not set</span>
            <% } %>
          </div>
        </div>
        <div class="set-card-body">
          <div class="field-group">
            <label for="ga4_id">GA4 Measurement ID</label>
            <div class="input-wrap">
              <i class="fas fa-chart-bar input-icon"></i>
              <input type="text" id="ga4_id" name="ga4_id"
                     value="<%= settings.ga4_id || '' %>"
                     placeholder="G-XXXXXXXXXX">
            </div>
            <span class="field-hint">
              <i class="fas fa-info-circle"></i>
              Google Analytics → Admin → Data Streams → Web → Measurement ID
            </span>
          </div>
          <div class="ga-preview">
            <i class="fas fa-chart-line"></i>
            <span>Once configured, your site traffic and user data will appear in your GA4 dashboard within 24 hours.</span>
          </div>
        </div>
      </div>

      <!-- ── SMTP / Email ───────────────────────────────────── -->
      <div class="set-card">
        <div class="set-card-top smtp-top">
          <div class="set-card-icon smtp-icon"><i class="fas fa-envelope"></i></div>
          <div>
            <h2>Email Notifications</h2>
            <p>Receive instant alerts when customers submit enquiries</p>
          </div>
          <div class="set-card-status">
            <% if (settings.smtp_user && settings.smtp_pass) { %>
              <span class="status-chip on"><i class="fas fa-circle"></i> Active</span>
            <% } else { %>
              <span class="status-chip off"><i class="fas fa-circle"></i> Not set</span>
            <% } %>
          </div>
        </div>
        <div class="set-card-body">
          <div class="field-row-2">
            <div class="field-group">
              <label for="smtp_host">SMTP Host</label>
              <div class="input-wrap">
                <i class="fas fa-server input-icon"></i>
                <input type="text" id="smtp_host" name="smtp_host"
                       value="<%= settings.smtp_host || 'smtp.gmail.com' %>"
                       placeholder="smtp.gmail.com">
              </div>
            </div>
            <div class="field-group">
              <label for="smtp_port">Port</label>
              <div class="input-wrap">
                <i class="fas fa-plug input-icon"></i>
                <input type="number" id="smtp_port" name="smtp_port"
                       value="<%= settings.smtp_port || '587' %>"
                       placeholder="587">
              </div>
            </div>
          </div>
          <div class="field-row-2">
            <div class="field-group">
              <label for="smtp_user">Email Address</label>
              <div class="input-wrap">
                <i class="fas fa-at input-icon"></i>
                <input type="email" id="smtp_user" name="smtp_user"
                       value="<%= settings.smtp_user || '' %>"
                       placeholder="your@gmail.com">
              </div>
            </div>
            <div class="field-group">
              <label for="smtp_pass">App Password</label>
              <div class="input-wrap">
                <i class="fas fa-key input-icon"></i>
                <input type="password" id="smtp_pass" name="smtp_pass"
                       value="<%= settings.smtp_pass || '' %>"
                       placeholder="16-character app password">
              </div>
            </div>
          </div>
          <div class="field-group">
            <label for="notify_email">Deliver Notifications To</label>
            <div class="input-wrap">
              <i class="fas fa-inbox input-icon"></i>
              <input type="email" id="notify_email" name="notify_email"
                     value="<%= settings.notify_email || '' %>"
                     placeholder="Defaults to SMTP address if blank">
            </div>
          </div>

          <!-- Gmail guide -->
          <div class="gmail-guide">
            <div class="gg-header">
              <i class="fab fa-google gg-icon"></i>
              <span>Gmail App Password Setup</span>
              <button type="button" class="gg-toggle" onclick="this.closest('.gmail-guide').classList.toggle('open')">
                <i class="fas fa-chevron-down"></i>
              </button>
            </div>
            <ol class="gg-steps">
              <li><strong>Enable 2-Step Verification</strong> — Google Account → Security → 2-Step Verification</li>
              <li><strong>Generate App Password</strong> — Security → App Passwords → Mail → Other (Custom name)</li>
              <li><strong>Copy the 16-character code</strong> and paste into App Password field above</li>
              <li><strong>Use your full Gmail</strong> as the username</li>
            </ol>
          </div>
        </div>
      </div>

    </form>
  </main>
</div>

<style>
/* ── Page Header ──────────────────────────────────── */
.pg-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 28px; flex-wrap: wrap; gap: 16px;
}
.pg-header-left { display: flex; align-items: center; gap: 16px; }
.pg-icon {
  width: 52px; height: 52px; border-radius: 14px;
  background: linear-gradient(135deg, rgba(200,151,75,.25), rgba(200,151,75,.05));
  border: 1px solid rgba(200,151,75,.25);
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; color: var(--gold); flex-shrink: 0;
}
.pg-title { font-family: var(--serif); font-size: 1.55rem; color: var(--text); line-height: 1.2; }
.pg-sub   { font-size: 13px; color: var(--muted); margin-top: 3px; }
.pg-save-btn {
  display: flex; align-items: center; gap: 8px;
  background: linear-gradient(135deg, var(--gold), var(--gold-dark));
  color: #111; border: none; padding: 12px 28px; border-radius: 10px;
  font-size: 14px; font-weight: 700; cursor: pointer;
  transition: opacity .2s, transform .15s; letter-spacing: .3px;
}
.pg-save-btn:hover { opacity: .9; transform: translateY(-1px); }

/* ── Alerts ───────────────────────────────────────── */
.pg-alert {
  display: flex; align-items: center; gap: 12px;
  padding: 14px 18px; border-radius: 10px; margin-bottom: 24px;
  font-size: 14px; font-weight: 600;
}
.pg-alert i:first-child { font-size: 16px; }
.pg-alert-close {
  margin-left: auto; background: none; border: none; cursor: pointer;
  font-size: 18px; line-height: 1; opacity: .6; color: inherit;
}
.pg-alert-success { background: rgba(56,161,105,.12); color: #68d391; border: 1px solid rgba(56,161,105,.2); }
.pg-alert-error   { background: rgba(229,62,62,.10); color: #fc8181; border: 1px solid rgba(229,62,62,.18); }

/* ── Settings Grid ────────────────────────────────── */
.settings-grid { display: flex; flex-direction: column; gap: 24px; }

/* ── Settings Card ────────────────────────────────── */
.set-card {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 16px; overflow: hidden;
  box-shadow: 0 2px 16px rgba(0,0,0,.18);
}
.set-card-top {
  display: flex; align-items: center; gap: 16px;
  padding: 22px 28px; border-bottom: 1px solid var(--border);
}
.ga-top   { background: linear-gradient(135deg, rgba(66,133,244,.06), rgba(66,133,244,.02)); }
.smtp-top { background: linear-gradient(135deg, rgba(200,151,75,.06), rgba(200,151,75,.02)); }
.set-card-icon {
  width: 46px; height: 46px; border-radius: 12px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 20px;
  background: linear-gradient(135deg, rgba(200,151,75,.2), rgba(200,151,75,.06));
  color: var(--gold); border: 1px solid rgba(200,151,75,.2);
}
.smtp-icon {
  background: linear-gradient(135deg, rgba(200,151,75,.2), rgba(200,151,75,.06));
}
.set-card-top h2 { font-family: var(--serif); font-size: 1.05rem; color: var(--text); margin-bottom: 3px; }
.set-card-top p  { font-size: 12.5px; color: var(--muted); margin: 0; }
.set-card-status { margin-left: auto; flex-shrink: 0; }
.status-chip {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 11.5px; font-weight: 700; padding: 5px 12px;
  border-radius: 20px; letter-spacing: .3px;
}
.status-chip.on  { background: rgba(56,161,105,.12); color: #68d391; border: 1px solid rgba(56,161,105,.2); }
.status-chip.on  i { font-size: 7px; color: #68d391; animation: pulse-green 2s infinite; }
.status-chip.off { background: rgba(255,255,255,.04); color: var(--muted); border: 1px solid var(--border); }
.status-chip.off i { font-size: 7px; }
@keyframes pulse-green {
  0%,100% { opacity: 1; } 50% { opacity: .4; }
}

/* ── Form Body ────────────────────────────────────── */
.set-card-body { padding: 28px; display: flex; flex-direction: column; gap: 22px; }
.field-row-2   { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.field-group   { display: flex; flex-direction: column; gap: 8px; }
.field-group label {
  font-size: 11.5px; color: var(--muted); font-weight: 700;
  letter-spacing: .8px; text-transform: uppercase;
}
.input-wrap    { position: relative; }
.input-icon    {
  position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
  color: var(--muted); font-size: 13px; pointer-events: none;
}
.input-wrap input {
  width: 100%; padding: 11px 14px 11px 40px;
  background: var(--bg); border: 1px solid var(--border);
  border-radius: 10px; color: var(--text); font-size: 14px;
  transition: border-color .2s, box-shadow .2s;
}
.input-wrap input:focus {
  outline: none; border-color: var(--gold);
  box-shadow: 0 0 0 3px rgba(200,151,75,.12);
}
.input-wrap input::placeholder { color: #3a3530; }
.field-hint {
  font-size: 11.5px; color: #4a4540; line-height: 1.5;
  display: flex; align-items: flex-start; gap: 5px;
}
.field-hint i { margin-top: 2px; flex-shrink: 0; }

/* ── GA preview strip ─────────────────────────────── */
.ga-preview {
  display: flex; align-items: center; gap: 14px;
  padding: 14px 18px; border-radius: 10px;
  background: rgba(66,133,244,.06); border: 1px solid rgba(66,133,244,.12);
  color: #82aecb; font-size: 12.5px; line-height: 1.55;
}
.ga-preview i { font-size: 22px; flex-shrink: 0; opacity: .7; }

/* ── Gmail Guide ──────────────────────────────────── */
.gmail-guide {
  border: 1px solid var(--border); border-radius: 10px; overflow: hidden;
}
.gg-header {
  display: flex; align-items: center; gap: 10px;
  padding: 14px 18px; background: rgba(255,255,255,.025);
  font-size: 13px; font-weight: 700; color: var(--text);
  cursor: pointer;
}
.gg-icon { color: var(--gold); font-size: 15px; }
.gg-toggle {
  margin-left: auto; background: none; border: none;
  color: var(--muted); font-size: 12px; cursor: pointer;
  transition: transform .3s;
}
.gmail-guide.open .gg-toggle { transform: rotate(180deg); }
.gg-steps {
  display: none; padding: 18px 20px 18px 36px;
  margin: 0; border-top: 1px solid var(--border);
}
.gmail-guide.open .gg-steps { display: block; }
.gg-steps li {
  font-size: 13px; color: var(--muted); margin-bottom: 10px;
  line-height: 1.55; padding-left: 4px;
}
.gg-steps li:last-child { margin-bottom: 0; }
.gg-steps strong { color: var(--text); }

@media (max-width: 640px) {
  .field-row-2 { grid-template-columns: 1fr; }
  .set-card-top { flex-wrap: wrap; }
  .set-card-status { width: 100%; }
  .pg-header { flex-direction: column; align-items: flex-start; }
}
</style>
