<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/images/logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<%- include('../partials/admin-nav') %>
<div class="admin-layout">
  <%- include('../partials/admin-sidebar') %>
  <main class="admin-main">
    <div class="admin-header">
      <h1><i class="fas fa-file-upload"></i> Import Products from Excel</h1>
      <a href="/admin/products" class="btn-admin-secondary"><i class="fas fa-arrow-left"></i> Back to Products</a>
    </div>

    <% if (typeof result !== 'undefined' && result) { %>
    <div class="import-result-card">
      <div class="import-result-header">
        <i class="fas fa-<%= result.imported > 0 ? 'check-circle result-ok' : 'exclamation-triangle result-warn' %>"></i>
        <h2>Import Complete</h2>
      </div>
      <div class="import-stats">
        <div class="istat istat-ok">
          <span class="istat-num"><%= result.imported %></span>
          <span class="istat-label">Products Imported</span>
        </div>
        <div class="istat istat-skip">
          <span class="istat-num"><%= result.skipped %></span>
          <span class="istat-label">Rows Skipped</span>
        </div>
        <div class="istat istat-total">
          <span class="istat-num"><%= result.total %></span>
          <span class="istat-label">Total Rows</span>
        </div>
      </div>
      <% if (result.errors && result.errors.length > 0) { %>
      <div class="import-errors">
        <h4><i class="fas fa-exclamation-triangle"></i> Skipped Rows</h4>
        <div class="error-list">
          <% result.errors.forEach(e => { %>
            <div class="error-row">
              <span class="error-row-num">Row <%= e.row %></span>
              <span class="error-msg"><%= e.reason %></span>
            </div>
          <% }) %>
        </div>
      </div>
      <% } %>
      <% if (result.imported > 0) { %>
        <a href="/admin/products" class="btn-admin-primary" style="margin-top:20px;display:inline-flex">
          <i class="fas fa-list"></i> View All Products
        </a>
      <% } %>
    </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>

    <!-- Upload Form -->
    <div class="import-grid">
      <div class="admin-card import-upload-card">
        <div class="card-header">
          <h2><i class="fas fa-cloud-upload-alt"></i> Upload Excel File</h2>
        </div>
        <div class="import-form-body">
          <form method="POST" action="/admin/products/import" enctype="multipart/form-data" id="importForm">
            <div class="drop-zone" id="dropZone">
              <div class="drop-icon"><i class="fas fa-file-excel"></i></div>
              <p class="drop-title">Drag & Drop your Excel file here</p>
              <p class="drop-sub">or click to browse</p>
              <input type="file" name="importFile" id="importFile" accept=".xlsx,.xls,.csv" class="drop-input">
              <p class="drop-formats">Accepted: .xlsx · .xls · .csv · Max 10MB</p>
            </div>
            <div class="file-selected" id="fileSelected" style="display:none">
              <i class="fas fa-file-excel file-icon"></i>
              <span id="fileName">file.xlsx</span>
              <button type="button" class="file-clear" id="fileClear"><i class="fas fa-times"></i></button>
            </div>
            <div class="import-options">
              <label class="check-label">
                <input type="checkbox" name="skip_duplicates" value="1" checked>
                <span class="check-text">Skip duplicate product names (same name + category)</span>
              </label>
              <label class="check-label">
                <input type="checkbox" name="overwrite_duplicates" value="1">
                <span class="check-text">Overwrite existing products if name + category match</span>
              </label>
            </div>
            <button type="submit" class="btn-admin-primary btn-import" id="importBtn" disabled>
              <i class="fas fa-upload"></i> Import Products
            </button>
          </form>
        </div>
      </div>

      <!-- Instructions -->
      <div class="import-help">
        <div class="admin-card">
          <div class="card-header"><h2><i class="fas fa-info-circle"></i> How to Use</h2></div>
          <div class="help-body">
            <div class="help-step">
              <div class="step-num">1</div>
              <div>
                <strong>Download the template</strong>
                <p>Use the template below with all required columns already formatted correctly.</p>
                <a href="/admin/products/import/template" class="btn-template">
                  <i class="fas fa-download"></i> Download Template (.xlsx)
                </a>
              </div>
            </div>
            <div class="help-step">
              <div class="step-num">2</div>
              <div>
                <strong>Fill in your products</strong>
                <p>One product per row. Start from row 2 (row 1 is the header).</p>
              </div>
            </div>
            <div class="help-step">
              <div class="step-num">3</div>
              <div>
                <strong>Upload &amp; Import</strong>
                <p>Select your file above and click Import. You'll see a full report of what was created.</p>
              </div>
            </div>
            <div class="img-note">
              <div class="img-note-icon"><i class="fas fa-image"></i></div>
              <div class="img-note-body">
                <strong>About Product Images</strong>
                <p>Excel cannot carry image files. Two ways to add images:</p>
                <ul>
                  <li><strong>Image URL column</strong> — paste any public https:// link and it saves automatically on import.</li>
                  <li><strong>Upload after import</strong> — leave Image URL blank, then open each product in Edit Product to upload a photo.</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <div class="admin-card" style="margin-top:20px">
          <div class="card-header"><h2><i class="fas fa-table"></i> Column Reference</h2></div>
          <div class="col-table-wrap">
            <table class="col-ref-table">
              <thead>
                <tr><th>Column Name</th><th>Required</th><th>Values / Format</th></tr>
              </thead>
              <tbody>
                <tr><td>Product Name</td><td><span class="req-badge">Required</span></td><td>Any text</td></tr>
                <tr><td>Category</td><td><span class="req-badge">Required</span></td><td>gold · diamond · silver</td></tr>
                <tr><td>Price (₹)</td><td><span class="req-badge">Required</span></td><td>Number only, e.g. 15000</td></tr>
                <tr><td>Weight</td><td><span class="opt-badge">Optional</span></td><td>Number, e.g. 8.5</td></tr>
                <tr><td>Weight Unit</td><td><span class="opt-badge">Optional</span></td><td>grams · carats · mg</td></tr>
                <tr><td>Purity</td><td><span class="opt-badge">Optional</span></td><td>22K · 18K · 95% · etc.</td></tr>
                <tr><td>Description</td><td><span class="opt-badge">Optional</span></td><td>Any text</td></tr>
                <tr><td>Featured</td><td><span class="opt-badge">Optional</span></td><td>Yes · No (default: No)</td></tr>
                <tr class="img-row"><td>Image URL</td><td><span class="opt-badge">Optional</span></td><td>https:// link to product photo</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<style>
.import-grid { display: grid; grid-template-columns: 1fr 440px; gap: 24px; align-items: start; }
.import-upload-card .card-header { padding: 18px 24px; border-bottom: 1px solid var(--border); }
.import-form-body { padding: 28px; }
.drop-zone { position: relative; border: 2px dashed var(--border); border-radius: 12px; padding: 48px 24px; text-align: center; cursor: pointer; transition: border-color .2s, background .2s; }
.drop-zone:hover, .drop-zone.drag-over { border-color: var(--gold); background: rgba(212,175,55,.04); }
.drop-input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
.drop-icon { font-size: 3rem; color: #27ae60; margin-bottom: 16px; }
.drop-title { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 6px; }
.drop-sub   { font-size: .85rem; color: var(--muted); margin-bottom: 12px; }
.drop-formats { font-size: .75rem; color: var(--muted); margin-top: 12px; }
.file-selected { display: flex; align-items: center; gap: 12px; background: rgba(39,174,96,.08); border: 1px solid rgba(39,174,96,.25); border-radius: 8px; padding: 12px 16px; margin-top: 16px; }
.file-icon  { font-size: 1.4rem; color: #27ae60; }
.file-selected span { flex: 1; font-size: .9rem; color: var(--text); font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.file-clear { background: none; border: none; color: var(--muted); cursor: pointer; font-size: .9rem; padding: 4px; transition: color .2s; }
.file-clear:hover { color: #e74c3c; }
.import-options { margin: 20px 0; display: flex; flex-direction: column; gap: 12px; }
.btn-import { width: 100%; justify-content: center; padding: 14px; font-size: 1rem; opacity: .5; cursor: not-allowed; transition: opacity .2s, background .2s; }
.btn-import.enabled { opacity: 1; cursor: pointer; }
.help-body { padding: 20px 24px; display: flex; flex-direction: column; gap: 20px; }
.help-step { display: flex; gap: 14px; }
.step-num { width: 28px; height: 28px; border-radius: 50%; background: var(--gold); color: #000; font-size: .8rem; font-weight: 900; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
.help-step strong { display: block; color: var(--text); margin-bottom: 4px; font-size: .9rem; }
.help-step p { font-size: .82rem; color: var(--muted); line-height: 1.5; margin-bottom: 8px; }
.btn-template { display: inline-flex; align-items: center; gap: 7px; background: rgba(39,174,96,.1); border: 1px solid rgba(39,174,96,.3); color: #27ae60; padding: 8px 16px; border-radius: 6px; font-size: .82rem; font-weight: 700; transition: background .2s; }
.btn-template:hover { background: rgba(39,174,96,.2); }
.col-table-wrap { overflow-x: auto; }
.col-ref-table { width: 100%; border-collapse: collapse; min-width: 340px; }
.col-ref-table th { padding: 10px 14px; text-align: left; font-size: .72rem; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; border-bottom: 1px solid var(--border); white-space: nowrap; }
.col-ref-table td { padding: 10px 14px; font-size: .82rem; border-bottom: 1px solid rgba(255,255,255,.04); color: var(--text); }
.col-ref-table tr:last-child td { border-bottom: none; }
.req-badge { background: rgba(231,76,60,.12); color: #e74c3c; font-size: .7rem; font-weight: 700; padding: 2px 8px; border-radius: 4px; }
.opt-badge { background: rgba(52,152,219,.1); color: #3498db; font-size: .7rem; font-weight: 700; padding: 2px 8px; border-radius: 4px; }
/* Result card */
.import-result-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 28px; margin-bottom: 28px; }
.import-result-header { display: flex; align-items: center; gap: 14px; margin-bottom: 24px; }
.import-result-header i { font-size: 2rem; }
.result-ok   { color: #27ae60; }
.result-warn { color: #e67e22; }
.import-result-header h2 { font-family: var(--serif); font-size: 1.4rem; color: var(--text); }
.import-stats { display: flex; gap: 16px; margin-bottom: 24px; }
.istat { flex: 1; padding: 18px; border-radius: 10px; text-align: center; }
.istat-ok   { background: rgba(39,174,96,.1); border: 1px solid rgba(39,174,96,.2); }
.istat-skip { background: rgba(231,76,60,.08); border: 1px solid rgba(231,76,60,.15); }
.istat-total { background: rgba(212,175,55,.08); border: 1px solid rgba(212,175,55,.15); }
.istat-num  { display: block; font-size: 2rem; font-weight: 700; font-family: var(--serif); }
.istat-ok   .istat-num { color: #27ae60; }
.istat-skip .istat-num { color: #e74c3c; }
.istat-total .istat-num { color: var(--gold); }
.istat-label { font-size: .78rem; color: var(--muted); }
.import-errors { background: rgba(231,76,60,.05); border: 1px solid rgba(231,76,60,.15); border-radius: 8px; padding: 16px; }
.import-errors h4 { color: #e74c3c; font-size: .85rem; margin-bottom: 12px; }
.error-list  { display: flex; flex-direction: column; gap: 8px; max-height: 240px; overflow-y: auto; }
.error-row   { display: flex; gap: 12px; font-size: .82rem; }
.error-row-num { color: var(--muted); white-space: nowrap; min-width: 48px; }
.error-msg   { color: #fc8181; }
.img-note { display: flex; gap: 14px; background: rgba(200,151,75,.06); border: 1px solid rgba(200,151,75,.2); border-radius: 10px; padding: 16px; margin-top: 4px; }
.img-note-icon { width: 36px; height: 36px; border-radius: 8px; background: rgba(200,151,75,.15); color: var(--gold); display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; margin-top: 2px; }
.img-note-body strong { display: block; color: var(--gold); font-size: .85rem; margin-bottom: 6px; }
.img-note-body p { font-size: .78rem; color: var(--muted); margin: 0 0 8px; }
.img-note-body ul { padding-left: 16px; margin: 0; }
.img-note-body li { font-size: .78rem; color: var(--muted); margin-bottom: 5px; line-height: 1.45; }
.img-note-body li strong { display: inline; color: var(--text); }
.img-row td { background: rgba(200,151,75,.04); }
@media (max-width: 900px) { .import-grid { grid-template-columns: 1fr; } }
</style>

<script>
const dropZone = document.getElementById('dropZone');
const fileInput = document.getElementById('importFile');
const fileSelected = document.getElementById('fileSelected');
const fileNameEl = document.getElementById('fileName');
const fileClear = document.getElementById('fileClear');
const importBtn = document.getElementById('importBtn');

function showFile(file) {
  if (!file) return;
  fileNameEl.textContent = file.name;
  fileSelected.style.display = 'flex';
  dropZone.style.display = 'none';
  importBtn.disabled = false;
  importBtn.classList.add('enabled');
}

fileInput.addEventListener('change', () => { if (fileInput.files[0]) showFile(fileInput.files[0]); });

fileClear.addEventListener('click', () => {
  fileInput.value = '';
  fileSelected.style.display = 'none';
  dropZone.style.display = '';
  importBtn.disabled = true;
  importBtn.classList.remove('enabled');
});

dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault(); dropZone.classList.remove('drag-over');
  const file = e.dataTransfer.files[0];
  if (file) {
    const dt = new DataTransfer(); dt.items.add(file); fileInput.files = dt.files;
    showFile(file);
  }
});

document.getElementById('importForm').addEventListener('submit', function() {
  importBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Importing…';
  importBtn.disabled = true;
});

// Mutual exclusion for checkboxes
const cbSkip = document.querySelector('[name=skip_duplicates]');
const cbOver = document.querySelector('[name=overwrite_duplicates]');
cbSkip.addEventListener('change', () => { if (cbSkip.checked) cbOver.checked = false; });
cbOver.addEventListener('change', () => { if (cbOver.checked) cbSkip.checked = false; });
</script>
<script src="/js/main.js"></script>
</body>
</html>
