<%- include('partials/header', { title, cartCount }) %>

<section class="success-section">
  <div class="container">
    <div class="success-card">
      <div class="success-icon-wrap">
        <div class="success-icon"><i class="fas fa-check"></i></div>
      </div>
      <h1 class="success-title">Enquiry Sent Successfully!</h1>
      <p class="success-sub">Thank you, <strong><%= inquiry.customer_name %></strong>! Your enquiry has been recorded.</p>

      <div class="success-details">
        <div class="detail-row">
          <span class="detail-label">Enquiry #</span>
          <span class="detail-value">#<%= inquiry.id %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Items</span>
          <span class="detail-value"><%= inquiry.items.length %> product(s)</span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Total Value</span>
          <span class="detail-value gold">₹<%= Number(inquiry.total).toLocaleString('en-IN') %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Phone</span>
          <span class="detail-value"><%= inquiry.customer_phone %></span>
        </div>
      </div>

      <div class="next-steps">
        <div class="step-card wa-step">
          <div class="step-icon"><i class="fab fa-whatsapp"></i></div>
          <div class="step-content">
            <h3>Chat on WhatsApp</h3>
            <p>Continue your enquiry on WhatsApp with all product details pre-filled. Our team will respond promptly.</p>
            <a href="<%= waLink %>" target="_blank" class="btn-wa-large">
              <i class="fab fa-whatsapp"></i> Open WhatsApp Chat
            </a>
          </div>
        </div>
        <% if (emailSent) { %>
          <div class="step-card email-step">
            <div class="step-icon"><i class="fas fa-envelope"></i></div>
            <div class="step-content">
              <h3>Email Notification Sent</h3>
              <p>Our team has also received an email notification with your enquiry details and will follow up with you.</p>
            </div>
          </div>
        <% } %>
      </div>

      <div class="enquired-items">
        <h3 class="items-title">Products You Enquired About</h3>
        <div class="items-list">
          <% inquiry.items.forEach(item => { %>
            <div class="success-item">
              <% if (item.image) { %>
                <img src="<%= item.image %>" alt="<%= item.name %>">
              <% } else { %>
                <div class="si-no-img"><i class="fas fa-gem"></i></div>
              <% } %>
              <div class="si-info">
                <span class="si-cat badge-<%= item.category %>"><%= item.category %></span>
                <p class="si-name"><%= item.name %></p>
              </div>
              <span class="si-price">₹<%= Number(item.price).toLocaleString('en-IN') %></span>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="success-actions">
        <a href="/" class="btn-home">
          <i class="fas fa-home"></i> Back to Home
        </a>
        <a href="/category/gold" class="btn-browse">
          <i class="fas fa-gem"></i> Browse More
        </a>
      </div>
    </div>
  </div>
</section>

<style>
.success-section { min-height: 80vh; display: flex; align-items: center; padding: 60px 0 80px; background: radial-gradient(ellipse at center top, rgba(212,175,55,.04), transparent 60%); }
.success-card  { max-width: 700px; margin: 0 auto; text-align: center; }
.success-icon-wrap { margin-bottom: 24px; }
.success-icon  { width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #1a3a1a, #0a1f0a); border: 2px solid #38a169; display: inline-flex; align-items: center; justify-content: center; font-size: 2rem; color: #68d391; animation: popIn .5s ease; }
@keyframes popIn { from { transform: scale(0); opacity: 0; } to { transform: scale(1); opacity: 1; } }
.success-title { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--gold); margin-bottom: 8px; }
.success-sub   { color: var(--muted); font-size: 1rem; margin-bottom: 32px; }
.success-sub strong { color: var(--text); }
.success-details { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 24px; margin-bottom: 32px; text-align: left; }
.detail-row    { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border); }
.detail-row:last-child { border-bottom: none; }
.detail-label  { color: var(--muted); font-size: .9rem; }
.detail-value  { font-weight: 600; color: var(--text); }
.detail-value.gold { color: var(--gold); font-size: 1.1rem; }
.next-steps    { display: flex; flex-direction: column; gap: 16px; margin-bottom: 32px; }
.step-card     { display: flex; gap: 20px; align-items: flex-start; background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 24px; text-align: left; }
.wa-step       { border-color: rgba(37,211,102,.3); background: rgba(37,211,102,.04); }
.email-step    { border-color: rgba(212,175,55,.2); }
.step-icon     { font-size: 2rem; flex-shrink: 0; }
.wa-step .step-icon   { color: #25d366; }
.email-step .step-icon { color: var(--gold); }
.step-content h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 6px; }
.step-content p  { font-size: .85rem; color: var(--muted); margin-bottom: 14px; line-height: 1.5; }
.btn-wa-large  { display: inline-flex; align-items: center; gap: 8px; background: #25d366; color: #fff; padding: 12px 24px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: .95rem; transition: opacity .2s; }
.btn-wa-large:hover { opacity: .85; }
.enquired-items { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 24px; margin-bottom: 32px; text-align: left; }
.items-title   { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--gold); margin-bottom: 16px; }
.success-item  { display: flex; align-items: center; gap: 16px; padding: 12px 0; border-bottom: 1px solid var(--border); }
.success-item:last-child { border-bottom: none; }
.success-item img { width: 50px; height: 50px; object-fit: cover; border-radius: 6px; }
.si-no-img     { width: 50px; height: 50px; border-radius: 6px; background: #1a1a1a; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; color: var(--border); flex-shrink: 0; }
.si-info       { flex: 1; }
.si-cat        { font-size: .65rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 2px 6px; border-radius: 3px; display: inline-block; margin-bottom: 4px; }
.badge-gold    { background: rgba(212,175,55,.15); color: var(--gold); }
.badge-diamond { background: rgba(155,184,212,.15); color: var(--diamond); }
.badge-silver  { background: rgba(184,184,184,.15); color: var(--silver); }
.si-name       { font-size: .9rem; color: var(--text); margin: 0; }
.si-price      { font-weight: 700; color: var(--gold); white-space: nowrap; }
.success-actions { display: flex; gap: 16px; justify-content: center; }
.btn-home      { background: var(--card); border: 1px solid var(--border); color: var(--text); padding: 12px 28px; border-radius: 8px; text-decoration: none; font-weight: 600; transition: border-color .2s; }
.btn-home:hover { border-color: var(--gold); color: var(--gold); }
.btn-browse    { background: linear-gradient(135deg, var(--gold), var(--gold-dark)); color: #000; padding: 12px 28px; border-radius: 8px; text-decoration: none; font-weight: 700; transition: opacity .2s; }
.btn-browse:hover { opacity: .85; }
</style>

<%- include('partials/footer') %>
